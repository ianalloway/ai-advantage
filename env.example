# Environment variables for AI Advantage Sports Betting App
# Copy this file to .env.local for local development or to Netlify env vars for deploys.

# Stripe client configuration
# Optional for client-side Stripe.js loading and payment-link fallbacks.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe payment-link fallbacks
# These are optional if you are using the server-created Checkout Session flow below.
VITE_STRIPE_CHECKOUT_URL=https://buy.stripe.com/test_your_checkout_url_here
VITE_STRIPE_ONE_TIME_CHECKOUT_URL=https://buy.stripe.com/test_your_one_time_url_here

# Stripe server-side Checkout Session flow
# Recommended for Netlify preview and production deploys.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PREMIUM_PRICE_ID=price_your_monthly_subscription_price_id
STRIPE_ONE_TIME_PRICE_ID=price_your_one_time_unlock_price_id
# Required for webhook fulfillment (checkout.session.completed, subscription lifecycle).
# Stripe Dashboard → Developers → Webhooks → endpoint signing secret (whsec_…).
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
STRIPE_AUTOMATIC_TAX=false
# Pro Monthly Checkout includes a free trial when > 0 (default 7).
STRIPE_TRIAL_DAYS=7
# Optional. Leave blank locally so the function infers localhost; set to https://aiadvantagesports.com in production if needed.
PUBLIC_APP_URL=https://aiadvantagesports.com

# Crypto unlock (optional). Without CRYPTO_PAYMENT_ADDRESS, verify-crypto-payment fails closed.
CRYPTO_PAYMENT_ADDRESS=0x_your_receive_wallet_here
ETH_RPC_URL=https://cloudflare-eth.com

# Newsletter intake automation
# Required for logging signups to Notion and emailing you each lead before the official Substack handoff.
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=AI Advantage <onboarding@yourdomain.com>
NOTIFY_EMAIL=ian@allowayllc.com
# Used by hourly edge alerts (send-edge-alerts) and daily trial nudges (send-trial-nudge).
SUBSTACK_PUBLICATION_URL=https://allowayai.substack.com

# Shared proof ledger storage
# Optional for account auth because Netlify Blobs is used by default.
# Recommended for the shared proof ledger if you want Redis-backed row history.
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
EXECUTION_LEDGER_KEY=ai-advantage:execution-ledger
# Required for trusted server-side writers that update the shared ledger API.
# Do not expose this as a VITE_* variable or send it from browser clients.
EXECUTION_LEDGER_WRITE_TOKEN=replace_with_a_long_random_secret
AUTH_SECRET=replace_with_a_long_random_server_secret

# The Odds API (server-side live sports lines)
# Sign up at https://the-odds-api.com/ to get your API key.
# Do not expose this key as a VITE_ variable.
# Free default: ESPN PickCenter lines (no key needed).
# Paid upgrade (optional): set USE_ODDS_API=true and a The Odds API key.
USE_ODDS_API=false
THE_ODDS_API_KEY=

# Optional: Backend API endpoint (if using a custom backend)
VITE_API_URL=http://localhost:3000/api

# Environment
# Set to 'production' for production builds
VITE_ENV=development
